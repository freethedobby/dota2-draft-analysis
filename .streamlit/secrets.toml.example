# Rename to secrets.toml for local use, OR paste these keys into Streamlit
# Community Cloud's "Settings → Secrets" UI after deploying.
# Lines starting with # are comments.

# Optional. Enables the "Upcoming matches (next 24h)" section.
# Free key from https://pandascore.co/ (100 req/hr tier is plenty).
PANDASCORE_API_KEY = "your_pandascore_token_here"
